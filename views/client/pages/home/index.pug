extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main 
  +alert-success(5000)

  .container.mt-4
    .row 
      .col-12.mb-3
        h3 Trang chủ

      .col-6.mb-2
        a(
          class="btn btn-outline-primary w-100"
          href="user/info"
        ) Thông tin cá nhân

      .col-6.mb-2
        a(
          class="btn btn-outline-warning w-100"
          href="/rooms-chat"
        ) Nhóm chat

      .col-6.mb-2
        a(
          class="btn btn-outline-secondary w-100"
          href="/users/not-friend"
        ) Danh sách người dùng

      .col-6.mb-2
        a(
          class="btn btn-outline-info w-100"
          href="/users/friends"
        ) Danh sách bạn bè
